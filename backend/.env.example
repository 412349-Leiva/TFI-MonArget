# Backend Environment Variables
# Copy this file to .env and fill in your credentials.
# Do NOT commit the .env file to version control.

# -- Database (MySQL local en tu PC) --
DB_USERNAME=root
DB_PASSWORD=your_db_password

# Produccion (MySQL externo): JDBC completo si migras la DB a la nube.
# SPRING_DATASOURCE_URL=jdbc:mysql://HOST:3306/monargent?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true

# -- Email (Gmail SMTP) --
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_google_app_password

# -- JWT Secret --
JWT_SECRET=your_jwt_secret_here

# -- OCR.Space API --
OCR_API_KEY=helloworld

# -- Google Gemini API --
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ===================================================================
# DESARROLLO LOCAL (npm run dev + spring-boot:run)
# ===================================================================
# APP_FRONTEND_URL=http://localhost:5173

# ===================================================================
# PRODUCCION: Vercel (front) + PC (back) + ngrok
# Ver README.md (sección Deploy)
# ===================================================================

# URL de tu deploy en Vercel (sin barra final)
APP_FRONTEND_URL=https://monargent-frontend.vercel.app

# CORS: permitir Vercel + ngrok
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://*.vercel.app,https://*.ngrok-free.app,https://*.ngrok-free.dev,https://*.ngrok.io,https://*.ngrok.app
