# Backend Environment Variables

# Copy this file to .env and fill in your credentials.

# Do NOT commit the .env file to version control.



# -- Database (MySQL local en tu PC) --

DB_USERNAME=root

DB_PASSWORD=your_db_password



# -- Email (Gmail SMTP) --

MAIL_USERNAME=your_email@gmail.com

MAIL_PASSWORD=your_google_app_password



# -- JWT Secret --

JWT_SECRET=your_jwt_secret_here



# -- OCR.Space API --

OCR_API_KEY=helloworld



# -- Google Gemini API --

GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.0-flash



# ===================================================================

# DESARROLLO LOCAL (npm run dev + spring-boot:run)

# ===================================================================

# APP_FRONTEND_URL=http://localhost:5173

# MERCADOPAGO_REDIRECT_URI=http://localhost:8080/api/v1/mercadopago/oauth/callback



# ===================================================================

# PRODUCCION: Vercel (front) + PC (back) + ngrok + MP produccion

# Ver DEPLOY-VERCEL.md

# ===================================================================



# URL de tu deploy en Vercel (sin barra final)

APP_FRONTEND_URL=https://frontend-beta-ten-40.vercel.app



# Dominio ngrok RESERVADO del backend (mismo que scripts/ngrok-backend.yml)

# MERCADOPAGO_REDIRECT_URI=https://monargent-api.ngrok-free.dev/api/v1/mercadopago/oauth/callback

MERCADOPAGO_REDIRECT_URI=https://blade-jot-uncommon.ngrok-free.dev/api/v1/mercadopago/oauth/callback



# Credenciales de PRODUCCION de Mercado Pago (Checkout Pro + OAuth)

MERCADOPAGO_CLIENT_ID=

MERCADOPAGO_CLIENT_SECRET=



# Opcional: fallback si un cobrador no conecto OAuth

MERCADOPAGO_ACCESS_TOKEN=



# CORS: permitir Vercel + ngrok

CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://*.vercel.app,https://*.ngrok-free.app,https://*.ngrok-free.dev,https://*.ngrok.io,https://*.ngrok.app

