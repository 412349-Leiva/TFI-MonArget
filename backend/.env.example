# Backend Environment Variables
# Copy this file to .env and fill in your credentials.
# Do NOT commit the .env file to version control.

# -- Database --
DB_USERNAME=root
DB_PASSWORD=your_db_password

# -- Email (Gmail SMTP) --
# Create an "App Password" for your Google Account for better security.
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_google_app_password

# -- JWT Secret --
# A strong, random string for signing JWTs.
JWT_SECRET=your_jwt_secret_here

# -- OCR.Space API --
# Free tier key at https://ocr.space/ocrapi
OCR_API_KEY=helloworld

# -- Google Gemini API --
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# -- CORS (demo PWA con ngrok) --
# Agregar URL HTTPS del frontend ngrok, separada por coma
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://xxxx.ngrok-free.app
