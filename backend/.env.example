# Backend Environment Variables
# Copy this file to .env and fill in your credentials.
# Do NOT commit the .env file to version control.

# -- Email (Gmail SMTP) --
# Create an "App Password" for your Google Account for better security.
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_google_app_password

# -- JWT Secret --
# A strong, random string for signing JWTs.
# You can generate one using an online tool.
JWT_SECRET=your-super-secret-jwt-key-that-is-long-and-random
