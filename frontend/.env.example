# URL del backend Spring Boot (context-path /api/v1)
#
# Desarrollo local: dejar comentado (usa proxy de Vite a :8080)
# VITE_API_URL=http://localhost:8080/api/v1
#
# Vercel + backend en PC con ngrok: setear en Vercel Dashboard (Production)
# VITE_API_URL=https://TU-BACKEND.ngrok-free.dev/api/v1
#
# Ver DEPLOY-VERCEL.md y frontend/.env.production.example
