# URL del backend Spring Boot (context-path /api/v1)
# Local sin ngrok: dejar comentado (usa proxy de Vite)
# VITE_API_URL=http://localhost:8080/api/v1

# Demo movil con ngrok: preferir app-config.json (generado por scripts/start-pwa-mobile.ps1)
# Si queres fijarlo manualmente al compilar:
# VITE_API_URL=https://TU-BACKEND.ngrok-free.app/api/v1
