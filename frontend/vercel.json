{
  "rewrites": [
    { "source": "/((?!assets|sw\\.js|workbox-.*|manifest\\.webmanifest|pwa-.*|favicon\\.svg|apple-touch-icon\\.png|app-config\\.json).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    }
  ]
}
